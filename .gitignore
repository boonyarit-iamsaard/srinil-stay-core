# Build output
/target/
/build/
out/
bin/
*.class
*.log
hs_err_pid*
replay_pid*

# Maven
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Keep nested source directories named target/build if they are intentional.
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

# Spring Boot / local runtime
.spring-boot-devtools.properties

# OS files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Local environment and secrets
.env
.env.*
!.env.example
*.local

# Local Codex state
.codex
.codex/

# VS Code: keep only shareable project recommendations/settings.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# Eclipse / STS
.apt_generated/
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
