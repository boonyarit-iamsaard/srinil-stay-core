# Normalize text files in the repository so Windows, macOS, Linux, and WSL
# all check out predictable line endings.
* text=auto eol=lf

# Platform-specific launchers.
/mvnw text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# Source and configuration files should stay LF in Git and working trees.
*.java text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.toml text eol=lf
*.dockerignore text eol=lf
.editorconfig text eol=lf
Dockerfile text eol=lf

# Binary files must not be line-ending normalized.
*.class binary
*.jar binary
*.war binary
*.zip binary
*.gz binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
